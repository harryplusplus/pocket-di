{
  "compilerOptions": {
    // Languages
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "erasableSyntaxOnly": true,
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": true,
    "types": [],

    // Types
    "skipLibCheck": true,
    "strict": true,

    // Builds
    "outDir": "dist",
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts"]
}
