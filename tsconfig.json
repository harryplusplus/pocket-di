{
  "compilerOptions": {
    // Languages
    "target": "es2019",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "erasableSyntaxOnly": true,
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": true,
    "types": [],

    // Types
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["packages/*/src/**/*.ts", "**/*.config*.ts"]
}
