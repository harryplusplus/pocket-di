{
  "compilerOptions": {
    // Languages
    "target": "es2017",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "erasableSyntaxOnly": true,
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": true,
    "types": [],
    "lib": ["es2017", "es2019.symbol"],

    // Types
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "packages/*/src/**/*.ts",
    "eslint.config.ts",
    "prettier.config.ts",
    "packages/*/vitest.config.*.ts"
  ]
}
