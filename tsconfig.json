{
  "compilerOptions": {
    // Languages
    "target": "es2017",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "erasableSyntaxOnly": true,
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": true,
    "types": [],
    "lib": ["dom", "es2017", "es2019.symbol"],

    // Types
    "skipLibCheck": true,
    "strict": true,

    // Builds
    "outDir": "dist",
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*.ts",
    "eslint.config.ts",
    "prettier.config.ts",
    "vitest.config.src.ts",
    "vitest.config.dist.ts"
  ]
}
