{
  "name": "pocket-di",
  "version": "0.1.0-dev.0",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "test:dist": "vitest --run -c vitest.config.dist.ts",
    "test:src": "vitest --run -c vitest.config.src.ts"
  },
  "publishConfig": {
    "access": "public"
  }
}
