{
  "name": "pocket-di",
  "version": "0.1.0-dev.0",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist",
    "test:js": "run-s clean build test:js:cmd",
    "test:js:cmd": "vitest --run -c vitest.config.js.ts",
    "test:ts": "vitest --run -c vitest.config.ts.ts",
    "lint": "eslint ."
  },
  "publishConfig": {
    "access": "public"
  }
}
