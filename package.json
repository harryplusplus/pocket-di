{
  "private": true,
  "type": "module",
  "scripts": {
    "check-types": "pnpm -r check-types",
    "clean": "pnpm -r --reverse clean",
    "format:all": "run-p format:md:all format:package-json",
    "format:md:all": "run-s format:md:toc format:md:md",
    "format:md:md": "markdownlint-cli2 --fix",
    "format:md:toc": "doctoc README.md README.ko.md",
    "format:package-json": "sort-package-json package.json packages/*/package.json",
    "lint": "eslint --fix",
    "test:js": "pnpm -r test:js",
    "test:ts": "pnpm -r test:ts"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.1",
    "@eslint/js": "9.39.2",
    "@types/node": "25.0.10",
    "@vitest/coverage-v8": "4.0.18",
    "doctoc": "2.2.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "jiti": "2.6.1",
    "markdownlint-cli2": "0.20.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "rimraf": "6.1.2",
    "sort-package-json": "3.6.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.1",
    "vitest": "4.0.18"
  }
}
