{
  "name": "pocket-di",
  "version": "0.1.0-development",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "dev": "tsc --noEmit --watch",
    "test": "vitest --run"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.0.17",
    "rimraf": "6.1.2",
    "typescript": "5.9.3",
    "vitest": "4.0.17"
  },
  "publishConfig": {
    "access": "public"
  }
}
